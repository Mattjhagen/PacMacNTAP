{
  "apps": [
    {
      "name": "pacmac-mobile",
      "script": "server.js",
      "instances": "max",
      "exec_mode": "cluster",
      "env": {
        "NODE_ENV": "production",
        "PORT": 3000
      },
      "error_file": "logs/err.log",
      "out_file": "logs/out.log",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "combine_logs": true,
      "merge_logs": true,
      "max_memory_restart": "500M",
      "autorestart": true,
      "watch": false
    }
  ]
}
